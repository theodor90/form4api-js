{
  "name": "form4api",
  "version": "1.1.3",
  "description": "TypeScript SDK for Form4API — real-time SEC Form 4 insider trading data",
  "keywords": [
    "insider-trading",
    "sec",
    "sec-edgar",
    "edgar",
    "form-4",
    "form4",
    "form-144",
    "13f",
    "13f-hr",
    "financial-data",
    "stock-market",
    "stocks",
    "fintech",
    "typescript",
    "sdk",
    "webhooks",
    "api",
    "form4api"
  ],
  "license": "MIT",
  "homepage": "https://www.form4api.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theodor90/form4api-js.git"
  },
  "bugs": {
    "url": "https://github.com/theodor90/form4api-js/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "msw": "^2.7.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
